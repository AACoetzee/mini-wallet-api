    {
      "name": "Demo",
      "item": [
        {
          "name": "Load Demo Accounts",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Demo data loaded', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const demo = pm.response.json();",
                  "pm.collectionVariables.set('primaryAccountId', demo.primaryAccountId);",
                  "pm.collectionVariables.set('secondaryAccountId', demo.secondaryAccountId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/demo/seed",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "demo",
                "seed"
              ]
            },
            "description": "Loads demo accounts, one balance adjustment, and one transfer. Also stores account IDs for later requests."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Accounts",
      "item": [
        {
          "name": "Create Primary Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Primary account created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const account = pm.response.json();",
                  "pm.collectionVariables.set('primaryAccountId', account.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"owner\": \"Jane Doe\",\n  \"type\": \"checking\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/accounts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "accounts"
              ]
            },
            "description": "Creates the first account and stores its ID as primaryAccountId."
          },
          "response": []
        },
        {
          "name": "Create Secondary Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Secondary account created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const account = pm.response.json();",
                  "pm.collectionVariables.set('secondaryAccountId', account.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"owner\": \"John Doe\",\n  \"type\": \"savings\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/accounts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "accounts"
              ]
            },
            "description": "Creates the second account and stores its ID as secondaryAccountId."
          },
          "response": []
        },
        {
          "name": "Find Accounts By Owner",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/accounts?owner=Jane",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "accounts"
              ],
              "query": [
                {
                  "key": "owner",
                  "value": "Jane"
                }
              ]
            },
            "description": "Finds account details when the account ID is unknown."
          },
          "response": []
        },
        {
          "name": "Get Primary Account Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/accounts/{{primaryAccountId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "accounts",
                "{{primaryAccountId}}"
              ]
            },
            "description": "Retrieves details for the primary account."
          },
          "response": []
        },
        {
          "name": "Get Primary Account Balance",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/accounts/{{primaryAccountId}}/balance",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "accounts",
                "{{primaryAccountId}}",
                "balance"
              ]
            },
            "description": "Retrieves the primary account balance."
          },
          "response": []
        },
        {
          "name": "Update Primary Account Balance",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"balance\": 1250\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/accounts/{{primaryAccountId}}/balance",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "accounts",
                "{{primaryAccountId}}",
                "balance"
              ]
            },
            "description": "Updates the primary account balance with PATCH."
          },
          "response": [],
          "description": "Updates the primary account balance with PATCH and creates a balance_adjustment transaction."
        }
      ]
    },
    {
      "name": "Transfers",
      "item": [
        {
          "name": "Transfer Funds",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromAccountId\": \"{{primaryAccountId}}\",\n  \"toAccountId\": \"{{secondaryAccountId}}\",\n  \"amount\": 200\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transfers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "transfers"
              ]
            },
            "description": "Transfers funds from the primary account to the secondary account."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "List Transactions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transactions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "transactions"
              ]
            },
            "description": "Lists all completed transfer transactions."
          },
          "response": []
        },
        {
          "name": "Filter Transactions By Account",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transactions?accountId={{primaryAccountId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "transactions"
              ],
              "query": [
                {
                  "key": "accountId",
                  "value": "{{primaryAccountId}}"
                }
              ]
            },
            "description": "Filters transaction history to records touching the primary account."
          },
          "response": []
        },
        {
          "name": "Filter Balance Adjustments",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transactions?accountId={{primaryAccountId}}&type=balance_adjustment&status=completed",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "transactions"
              ],
              "query": [
                {
                  "key": "accountId",
                  "value": "{{primaryAccountId}}"
                },
                {
                  "key": "type",
                  "value": "balance_adjustment"
                },
                {
                  "key": "status",
                  "value": "completed"
                }
              ]
            },
            "description": "Shows balance update history as balance_adjustment transactions."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Error Cases",
      "item": [
        {
          "name": "Unauthorized Request",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/accounts/{{primaryAccountId}}/balance",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "accounts",
                "{{primaryAccountId}}",
                "balance"
              ]
            },
            "description": "Shows the structured UNAUTHORIZED error when x-api-key is missing."
          },
          "response": []
        },
        {
          "name": "Invalid Balance Update",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"balance\": -10\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/accounts/{{primaryAccountId}}/balance",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "accounts",
                "{{primaryAccountId}}",
                "balance"
              ]
            },
            "description": "Shows validation for invalid balance updates."
          },
          "response": []
        },
        {
          "name": "Insufficient Funds Transfer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromAccountId\": \"{{primaryAccountId}}\",\n  \"toAccountId\": \"{{secondaryAccountId}}\",\n  \"amount\": 999999\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transfers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "transfers"
              ]
            },
            "description": "Shows the structured INSUFFICIENT_FUNDS error response."
          },
          "response": []
        }
      ]
    }
  ],
